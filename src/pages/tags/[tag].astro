---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { tagColor } from '../../lib/tags';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];
  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<Base title={tag}>
  <header class="tag-head" style={`--c:${tagColor(tag)}`}>
    <h1>{tag}</h1>
    <p class="tag-meta">{posts.length} {posts.length === 1 ? 'entry' : 'entries'}</p>
  </header>
  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <a href={`/posts/${post.id}`}>{post.data.title}</a>
        <time>{post.data.date.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' })}</time>
      </li>
    ))}
  </ul>
</Base>
<style>
  .tag-head h1 { margin-bottom: 0; }
  .tag-head .tag-meta { color: var(--c); font-size: 0.85rem; font-weight: 600; margin: 0.25rem 0 0; }
  .tag-head h1::after { content: ''; display: block; width: 2.5rem; height: 3px; margin-top: 0.5rem; border-radius: 2px; background: var(--c); }
</style>
