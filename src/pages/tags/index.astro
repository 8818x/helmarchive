---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { tagColor } from '../../lib/tags';

const posts = await getCollection('posts');
const tagCount = new Map<string, number>();
for (const p of posts) for (const t of p.data.tags) tagCount.set(t, (tagCount.get(t) ?? 0) + 1);
const tags = [...tagCount.entries()].sort((a, b) => b[1] - a[1]);
---

<Base title="Tags">
  <ul class="tags">
    {tags.map(([tag, count]) => (
      <li>
        <a class="tag-card" href={`/tags/${encodeURIComponent(tag)}`} style={`--c:${tagColor(tag)}`}>
          <span class="tnum" aria-hidden="true">{count}</span>
          <span class="tname">{tag}</span>
        </a>
      </li>
    ))}
  </ul>
</Base>
