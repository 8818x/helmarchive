---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { parseMentions, resolve } from '../../lib/wikilinks';

export async function getStaticPaths() {
  const [entities, posts] = await Promise.all([getCollection('entities'), getCollection('posts')]);
  return entities.map((entity) => ({
    params: { id: entity.id },
    props: {
      entity,
      // backlinks: posts whose body mentions this entity (by slug or name).
      // ponytail: raw-body regex scan — a [[x]] inside a code fence would false-positive;
      // rare enough to ignore, upgrade to AST scan only if it bites.
      backlinks: posts
        .filter((p) =>
          parseMentions(p.body ?? '').some((m) => m.mention && resolve(m.mention.target)?.slug === entity.id)
        )
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { entity, backlinks } = Astro.props;
const e = entity.data;
---

<Base title={`${e.name} · helmarchive`}>
  <article class="entity">
    <header class="entity-head">
      {e.image && <img src={e.image} alt={e.name} loading="lazy" />}
      <div class="entity-meta">
        <h1>{e.name}</h1>
        {e.full_name && <p class="full-name">{e.full_name}</p>}
        {e.kind && <p class="kind">{e.kind}</p>}
        {e.url && (
          <a class="official" href={e.url} target="_blank" rel="nofollow noopener noreferrer">
            Official site ↗
          </a>
        )}
      </div>
    </header>

    {e.blurb && <p class="blurb">{e.blurb}</p>}

    <section class="backlinks">
      <h2>{backlinks.length ? `Mentioned in ${backlinks.length}` : 'Not mentioned yet'}</h2>
      {backlinks.length > 0 && (
        <ul>
          {backlinks.map((p) => (
            <li>
              <a href={`/posts/${p.id}`}>{p.data.title}</a>
              <time>{p.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
            </li>
          ))}
        </ul>
      )}
    </section>
  </article>
</Base>

<style>
  /* ponytail: cap to a square box so a portrait photo shrinks instead of towering
     over short meta; center meta against the image — kills the hollow gap. */
  .entity-head { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  .entity-head img { max-width: 12rem; max-height: 12rem; width: auto; height: auto; border-radius: 3px; flex-shrink: 0; }
  .entity-meta { min-width: 0; }
  .entity-meta h1 { margin: 0; }
  .full-name { color: var(--rp-subtle); font-size: 1rem; font-weight: 500; margin: 0.15rem 0 0; }
  .kind { color: var(--rp-subtle); font-size: 0.9rem; margin: 0.25rem 0 0; }
  .official { display: inline-block; margin-top: 0.9rem; color: var(--link); }
  .blurb { font-size: 1.05rem; line-height: 1.6; max-width: 42rem; margin-top: 1.5rem; }
  .backlinks { margin-top: 2.5rem; padding-top: 1rem; border-top: 1px solid var(--line); }
  .backlinks ul { list-style: none; padding: 0; }
  .backlinks li { padding: 0.4rem 0; }
  .backlinks time { color: var(--rp-subtle); font-size: 0.85rem; margin-left: 0.6rem; }
</style>
